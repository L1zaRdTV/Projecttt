<Window x:Class="GenericStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenericStore"
        mc:Ignorable="d"
        Title="Универсальный магазин" Height="640" Width="1040" MinWidth="1000" MinHeight="560"
        Background="#F4F4F2" WindowStartupLocation="CenterScreen">
    <Border Margin="18" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
        <Frame x:Name="Mainframe" NavigationUIVisibility="Hidden"/>
    </Border>
</Window>
