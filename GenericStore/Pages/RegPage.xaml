<Page x:Class="GenericStore.Pages.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GenericStore.Pages"
      mc:Ignorable="d" d:DesignWidth="800" MinHeight="550"
      Title="RegPage">

    <Grid Background="#F4F4F2">
        <Border Width="430" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Регистрация" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Заполните поля для создания аккаунта" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,22"/>

                <Label Content="Логин"/>
                <TextBox x:Name="LoginBox" Height="38" Margin="0,4,0,12" AutomationProperties.Name="LoginBox" TabIndex="1" MaxLength="50"/>

                <Label Content="Пароль"/>
                <PasswordBox x:Name="PassBox" Height="38" Margin="0,4,0,12" AutomationProperties.Name="PassBox" PasswordChanged="PassBox_PasswordChanged" TabIndex="2" MaxLength="50"/>

                <Label Content="Подтверждение пароля"/>
                <PasswordBox x:Name="PassBoxV" Height="38" Margin="0,4,0,12" AutomationProperties.Name="PassBoxV" PasswordChanged="PassBoxV_PasswordChanged" TabIndex="3" MaxLength="50"/>

                <Label Content="Почта"/>
                <TextBox x:Name="EmailBox" Height="38" Margin="0,4,0,12" AutomationProperties.Name="EmailBox" TabIndex="4" MaxLength="100"/>

                <Label Content="Город"/>
                <ComboBox x:Name="CityBox" Height="38" Margin="0,4,0,24" AutomationProperties.Name="CityBox" TabIndex="5"
                          DisplayMemberPath="NameCity" SelectedValuePath="IdCity"/>

                <Button x:Name="AddButton" Content="Зарегистрироваться" Height="40" Click="AddButton_Click"/>
                <Button x:Name="GoToAutogizButton" Content="Назад к авторизации" Height="40" Margin="0,10,0,0" Background="#EEF2FF" Foreground="#4B5563" Click="GoToAutogizButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
