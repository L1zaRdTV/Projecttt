<Window x:Class="GenericStore.Pages.ProductEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Банкетная комната" Height="430" Width="520" MinWidth="360" MinHeight="420" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="16" Padding="18" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,14"/>
            <TextBlock Grid.Row="1" Text="Название комнаты"/>
            <TextBox x:Name="ProductNameBox" Grid.Row="1" Margin="0,22,0,10" Height="30" MaxLength="100"/>
            <TextBlock Grid.Row="2" Text="Стиль оформления"/>
            <ComboBox x:Name="CategoryBox" Grid.Row="2" Margin="0,22,0,10" Height="30" DisplayMemberPath="NameCategory" SelectedValuePath="IdCategory"/>
            <TextBlock Grid.Row="3" Text="Стоимость аренды"/>
            <TextBox x:Name="PriceBox" Grid.Row="3" Margin="0,22,0,10" Height="30" MaxLength="50"/>
            <TextBlock Grid.Row="4" Text="Изображение"/>
            <TextBox x:Name="PhotoPathBox" Grid.Row="4" Margin="0,22,0,10" Height="30" GotFocus="PhotoPathBox_GotFocus"/>
            <TextBlock Grid.Row="5" Text="Описание комнаты"/>
            <TextBox x:Name="DescriptionBox" Grid.Row="5" Margin="0,22,0,10" Height="76" TextWrapping="Wrap" AcceptsReturn="True" MaxLength="1000" VerticalContentAlignment="Top"/>
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Width="110" Height="34" Margin="0,0,10,0" Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" Content="Сохранить" Width="130" Height="34" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
