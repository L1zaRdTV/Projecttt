<Page x:Class="GenericStore.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProfilePage" Background="#F4F4F2">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,18" LastChildFill="True">
            <Button Content="← В магазин" Width="110" Height="36" Click="BackButton_Click" Background="#F1F1F1" Foreground="#374151" BorderBrush="#CFCFCF" DockPanel.Dock="Left"/>
            <TextBlock Text="Профиль пользователя" Margin="18,3,0,0" FontSize="24" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border MaxWidth="560" MinWidth="300" HorizontalAlignment="Center" VerticalAlignment="Top" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="26">
            <StackPanel>
                <TextBlock Text="Редактор профиля" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>
                <TextBlock Text="Логин" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBox x:Name="NameBox" Height="34" Margin="0,6,0,14" MaxLength="100"/>
                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#374151"/>
                <TextBox x:Name="EmailBox" Height="34" Margin="0,6,0,14" MaxLength="100"/>
                <TextBlock Text="Город" FontWeight="SemiBold" Foreground="#374151"/>
                <ComboBox x:Name="CityBox" Height="34" Margin="0,6,0,14" DisplayMemberPath="NameCity" SelectedValuePath="IdCity"/>
                <TextBlock Text="Новый пароль (можно оставить пустым)" FontWeight="SemiBold" Foreground="#374151"/>
                <PasswordBox x:Name="PasswordBox" Height="34" Margin="0,6,0,20" MaxLength="100"/>
                <Button Content="Сохранить изменения" Width="190" Height="40" HorizontalAlignment="Left" Click="SaveButton_Click" Background="#4B5563" Foreground="White" FontWeight="SemiBold" BorderThickness="0"/>
            </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
