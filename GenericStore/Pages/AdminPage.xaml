<Page x:Class="GenericStore.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="14" Padding="16" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Панель администратора" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <TextBlock Text="Управление товарами, категориями и пользователями" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,0,0,22"/>

                <Button Content="Товары" Height="38" Margin="0,0,0,10" Click="ProductsButton_Click"/>
                <Button Content="Категории" Height="38" Margin="0,0,0,10" Click="CategoriesButton_Click"/>
                <Button Content="Пользователи" Height="38" Margin="0,0,0,18" Click="UsersButton_Click"/>

                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Margin="0,4,0,18"/>
                <Button x:Name="GoToCatalogButton" Content="Назад к каталогу" Height="38" Click="GoToCatalogButton_Click" Background="#666666"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Margin="0,14,14,14" Padding="14" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
            <Frame x:Name="AdminContentFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Page>
