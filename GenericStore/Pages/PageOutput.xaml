<Page x:Class="GenericStore.Pages.PageOutput"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="1050"
      Title="Банкетные комнаты" Background="#F4F4F2">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Бронирование банкетных комнат" FontSize="28" TextWrapping="Wrap" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Ознакомьтесь с банкетными комнатами, используйте поиск, фильтр по стилю и сортировку по стоимости аренды." Foreground="#666666" Margin="0,4,12,0" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ProfileButton" Content="Сменить пользователя" Height="36" Width="100" Margin="0,0,8,0" Click="ProfileButton_Click" Background="#F1F1F1" Foreground="#374151" BorderBrush="#CFCFCF"/>
                <Button x:Name="AddProductsButton" Content="Управление комнатами" Height="36" Width="130" Margin="0,0,8,0" Click="AddProductsButton_Click" Loaded="AddProductsButton_Loaded" Foreground="White" Background="#4B5563" BorderThickness="0"/>

            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,18">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Width="220" MinWidth="160" Margin="0,0,14,10">
                    <TextBlock Text="Стиль оформления" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ComboFilter" Height="34" SelectionChanged="ComboFilter_SelectionChanged"/>
                </StackPanel>
                <StackPanel Width="170" MinWidth="140" Margin="0,0,14,10">
                    <TextBlock Text="Стоимость аренды" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ComboSort" Height="34" SelectionChanged="ComboSort_SelectionChanged"/>
                </StackPanel>
                <StackPanel Width="260" MinWidth="180" Margin="0,0,0,10">
                    <TextBlock Text="Поиск" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <TextBox x:Name="TextSearch" Height="34" TextChanged="TextSearch_TextChanged" MaxLength="100" ToolTip="Введите название или описание комнаты"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <ListView x:Name="ListProducts" Grid.Row="2" Background="Transparent" BorderThickness="0" MouseDoubleClick="ListProducts_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,14"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="14">
                        <DockPanel LastChildFill="True">
                            <Border Width="132" Height="132" Background="#F3F4F6" ClipToBounds="True" DockPanel.Dock="Left" Margin="0,0,18,0">
                                <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel DockPanel.Dock="Right" Width="150" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock Text="{Binding Price, StringFormat={}{0:N2} ₽/час}" FontSize="22" FontWeight="Bold" Foreground="#4B5563" HorizontalAlignment="Right" TextWrapping="Wrap"/>

                            </StackPanel>
                            <StackPanel MinWidth="120">
                                <TextBlock Text="{Binding Product}" FontSize="20" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,8,0,0" Foreground="#666666" TextWrapping="Wrap" MaxHeight="44" Text="{Binding Descripton}"/>
                                <TextBlock Margin="0,10,0,0" Foreground="#555555" FontWeight="SemiBold" Text="{Binding Categories.NameCategory, StringFormat=Стиль: {0}}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0" Foreground="#555555" FontWeight="SemiBold" Text="{Binding TablesDisplay}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="tbCounter" Grid.Row="3" Margin="0,10,0,0" Foreground="#666666" FontWeight="SemiBold"/>
    </Grid>
</Page>
