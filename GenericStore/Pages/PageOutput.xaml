<Page x:Class="GenericStore.Pages.PageOutput"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="1050" MinHeight="560"
      Title="PageOutput" Background="#F4F4F2">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Универсальный магазин" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Выбирайте товары, открывайте подробности двойным кликом и добавляйте покупки в корзину." Foreground="#666666" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ProfileButton" Content="Профиль" Height="36" Width="100" Margin="0,0,8,0" Click="ProfileButton_Click" Background="#EEF2FF" Foreground="#374151" BorderBrush="#C7D2FE"/>
                <Button x:Name="AddProductsButton" Content="Админ-панель" Height="36" Width="130" Margin="0,0,8,0" Click="AddProductsButton_Click" Loaded="AddProductsButton_Loaded" Foreground="White" Background="#4B5563" BorderThickness="0"/>
                <Button x:Name="GoToBasketButton" Content="Корзина" Height="36" Width="95" Foreground="White" Background="#10B981" BorderThickness="0" Click="GoToBasketButton_Click_1"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" Padding="18" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Text="Категория" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ComboFilter" Height="34" SelectionChanged="ComboFilter_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Text="Цена" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ComboSort" Height="34" SelectionChanged="ComboSort_SelectionChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Поиск" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,6"/>
                    <TextBox x:Name="TextSearch" Height="34" TextChanged="TextSearch_TextChanged" MaxLength="100" ToolTip="Введите название товара"/>
                </StackPanel>
            </Grid>
        </Border>

        <ListView x:Name="ListProducts" Grid.Row="2" Background="Transparent" BorderThickness="0" MouseDoubleClick="ListProducts_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0,0,0,14"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="132" Height="132" CornerRadius="14" Background="#F3F4F6" ClipToBounds="True">
                                <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="18,0,18,0">
                                <TextBlock Text="{Binding Product}" FontSize="20" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,8,0,0" Foreground="#666666" TextWrapping="Wrap" MaxHeight="44" Text="{Binding Descripton}"/>
                                <TextBlock Margin="0,10,0,0" Foreground="#047857" FontWeight="SemiBold" Text="{Binding Categories.NameCategory}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Price, StringFormat={}{0:N2} ₽}" FontSize="22" FontWeight="Bold" Foreground="#4B5563" HorizontalAlignment="Right"/>
                                <Button x:Name="AddToBusketButton" Content="В корзину" Margin="0,18,0,0" Height="36" Width="130" HorizontalAlignment="Right" Foreground="White" Background="#4B5563" BorderThickness="0" Click="AddToBusketButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="tbCounter" Grid.Row="3" Margin="0,10,0,0" Foreground="#666666" FontWeight="SemiBold"/>
    </Grid>
</Page>
