<Page x:Class="GenericStore.Pages.Authoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GenericStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Authoriz">

    <Grid Background="#F6F7FB">
        <Border Width="380" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Вход" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Введите данные учетной записи" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <Label Content="Логин"/>
                <TextBox x:Name="LoginBox" Height="38" Margin="0,4,0,16" AutomationProperties.Name="LoginBox" TabIndex="1" MaxLength="50"/>

                <Label Content="Пароль"/>
                <PasswordBox x:Name="PassBox" Height="38" Margin="0,4,0,24" AutomationProperties.Name="PassBox" TabIndex="2" MaxLength="50"/>

                <Button x:Name="LoginButton" Content="Войти" Height="40" Click="LoginButton_Click"/>
                <Button x:Name="OpenRegButton" Content="Создать аккаунт" Height="40" Margin="0,10,0,0" Background="#EEF2FF" Foreground="#2563EB" Click="OpenRegButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
